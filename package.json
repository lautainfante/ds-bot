{
  "name": "ds-bot",
  "version": "0.1.0",
  "description": "Discord music bot with free and premium tiers",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "keywords": [
    "discord",
    "music-bot",
    "typescript",
    "premium"
  ],
  "license": "MIT",
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.2",
    "discord.js": "^14.19.3",
    "dotenv": "^16.4.5",
    "ffmpeg-static": "^5.2.0",
    "jpeg-js": "^0.4.4",
    "opusscript": "^0.0.8",
    "play-dl": "^1.9.7",
    "pngjs": "^7.0.0",
    "prism-media": "^1.3.5",
    "youtubei.js": "^17.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/pngjs": "^6.0.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
